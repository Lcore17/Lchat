# Backend runtime configuration
PORT=5000
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d

# Comma separated frontend origins
CORS_ORIGINS=http://localhost:19006,http://localhost:8081

# Message encryption key (required for encrypted message text)
# Use a long random secret and keep it the same between restarts.
MESSAGE_ENCRYPTION_KEY=replace-with-a-long-random-secret
